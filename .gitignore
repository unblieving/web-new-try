# Dependencies and package-manager state
/node_modules/
/frontend/node_modules/
/backend/node_modules/
/.npm/
/.yarn/
.pnp
.pnp.*

# Environment variables and local secrets
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key

# Frontend: Next.js, Tailwind CSS, and hosting output
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/.vercel/
/frontend/.swc/
/frontend/next-env.d.ts

# Backend: Midway.js build and runtime output
/backend/dist/
/backend/logs/
/backend/run/
/backend/.midway-run/
/backend/.midway-serverless/
/backend/.faas_debug_tmp/

# Runtime database files; keep the empty directory marker
/backend/data/*
!/backend/data/.gitkeep

# Root-level and shared build caches
/dist/
/build/
/out/
/.cache/
/.turbo/
*.tsbuildinfo

# Tests and coverage
/coverage/
/frontend/coverage/
/backend/coverage/
/.nyc_output/
/playwright-report/
/test-results/
/frontend/playwright-report/
/frontend/test-results/

# Logs, process files, and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
*.pid.lock
*.seed
*.swp
*.swo
*~
/tmp/
/temp/

# Editors and IDEs
/.idea/
/.vscode/
/.fleet/
*.iml

# Operating-system metadata
.DS_Store
._*
Thumbs.db
Desktop.ini
